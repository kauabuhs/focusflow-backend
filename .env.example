# ============================================================================
# FocusFlow Backend - Environment Configuration
# ============================================================================
# This file contains sensitive configuration. DO NOT commit to version control.
# Add .env to .gitignore
#
# Usage:
#   1. Copy this file: cp .env.example .env
#   2. Update values as needed for your environment
#   3. Never commit .env to git
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Prisma ORM Database Connection String
# Format: postgresql://user:password@host:port/database?schema=public

DATABASE_URL="postgresql://focusflow:focusflow2026@localhost:5432/focusflow?schema=public"

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# API Server Port
PORT=3000

# Environment: development | staging | production
NODE_ENV=development

# API Base URL (for CORS and external calls)
API_BASE_URL=http://localhost:3000

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Allowed origins for CORS requests
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================================================
# AUTHENTICATION
# ============================================================================
# JWT Secret (generate a strong random string in production)
JWT_SECRET=your-secret-jwt-key-change-this-in-production

# JWT Expiration time (e.g., 7d, 24h, 1w)
JWT_EXPIRATION=7d

# ============================================================================
# LOGGING
# ============================================================================
# Log Level: error | warn | info | debug | trace
LOG_LEVEL=debug

# ============================================================================
# FEATURES
# ============================================================================
# Enable request logging
ENABLE_REQUEST_LOGGING=true

# Enable API documentation (Swagger/OpenAPI)
ENABLE_API_DOCS=true

# ============================================================================
# DEVELOPMENT
# ============================================================================
# Auto-reload on file changes (tsx handles this)
WATCH_MODE=true

# Print SQL queries (Prisma debug logging)
DEBUG=prisma:*
